{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"types": ["bun-types"],
		"lib": ["ES2022", "DOM", "DOM.Iterable"],
		"outDir": "./dist",
		"rootDir": "./src",
		"strict": true,
		"skipLibCheck": true,
		"verbatimModuleSyntax": true
	},
	"include": ["src/**/*.ts"]
}
