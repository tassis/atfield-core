{
	"name": "atfield-core",
	"version": "0.1.1",
	"type": "module",
	"repository": {
    "type": "git",
    "url": "https://github.com/tassis/atfield-core"
  },
	"imports": {
		"#core/core": "./src/core.ts",
		"#core/core.types": "./src/core.types.ts",
		"#core/errors": "./src/errors.ts",
		"#core/schema": "./src/schema.ts",
		"#core/types": "./src/types.ts",
		"#core/did": "./src/did/index.ts",
		"#core/did/*": "./src/did/*",
		"#core/identity": "./src/identity/index.ts",
		"#core/identity/*": "./src/identity/*",
		"#core/repo": "./src/repo/index.ts",
		"#core/repo/*": "./src/repo/*",
		"#core/transport": "./src/transport/index.ts",
		"#core/transport/*": "./src/transport/*",
		"#core/providers": "./src/providers/index.ts",
		"#core/providers/*": "./src/providers/*",
		"#core/providers/bsky": "./src/providers/bsky/index.ts",
		"#core/providers/bsky/*": "./src/providers/bsky/*",
		"#core/providers/standardsite": "./src/providers/standardsite/index.ts",
		"#core/providers/standardsite/*": "./src/providers/standardsite/*",
		"#core/providers/whitewind": "./src/providers/whitewind/index.ts",
		"#core/providers/whitewind/*": "./src/providers/whitewind/*"
	},
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		},
		"./transport": {
			"types": "./dist/transport.d.ts",
			"default": "./dist/transport.js"
		},
		"./identity": {
			"types": "./dist/identity.d.ts",
			"default": "./dist/identity.js"
		},
		"./did": {
			"types": "./dist/did.d.ts",
			"default": "./dist/did.js"
		},
		"./repo": {
			"types": "./dist/repo.d.ts",
			"default": "./dist/repo.js"
		},
		"./providers/bsky": {
			"types": "./dist/providers/bsky.d.ts",
			"default": "./dist/providers/bsky.js"
		},
		"./providers/standardsite": {
			"types": "./dist/providers/standardsite.d.ts",
			"default": "./dist/providers/standardsite.js"
		},
		"./providers/whitewind": {
			"types": "./dist/providers/whitewind.d.ts",
			"default": "./dist/providers/whitewind.js"
		}
	},
	"files": ["dist"],
	"publishConfig": {
		"access": "public",
		"registry": "https://registry.npmjs.org/"
	},
	"scripts": {
		"build": "tsup",
		"check": "tsc --noEmit -p tsconfig.json",
		"lint": "eslint .",
		"format": "prettier --write .",
		"test": "bun test",
		"verify:packed-consumer": "bun run ./scripts/verify-packed-consumer.mjs"
	},
	"devDependencies": {
		"@eslint/compat": "^2.0.4",
		"@eslint/js": "^10.0.1",
		"bun-types": "^1.3.14",
		"eslint": "^10.2.0",
		"eslint-config-prettier": "^10.1.8",
		"globals": "^17.4.0",
		"prettier": "^3.8.1",
		"tsup": "^8.5.1",
		"typescript": "^6.0.2",
		"typescript-eslint": "^8.58.1"
	}
}
